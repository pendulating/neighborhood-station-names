{
  "name": "neighborhood-station-names",
  "version": "0.2.1",
  "description": "Subway Builder mod: name stations after nearby neighborhoods instead of roads",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k -n build,game -c blue,green \"vite build --watch\" \"tsx scripts/run.ts\"",
    "dev:link": "tsx scripts/link.ts",
    "dev:unlink": "tsx scripts/link.ts --unlink",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "subway-builder",
    "mod"
  ],
  "author": {
    "name": "Matt Franchi",
    "url": "https://mfranchi.net"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.9",
    "@vitest/coverage-v8": "^4.1.10",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.11.1",
    "maplibre-gl": "^5.18.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vite": "npm:rolldown-vite@latest",
    "vite-plugin-static-copy": "^3.0.0",
    "vitest": "^4.1.10"
  }
}
